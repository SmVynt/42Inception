# Non-secret values only.
# Passwords: ../secrets/db_root_password.txt, db_password.txt, wp_password.txt (WP admin — see secrets/*.example)

MARIA_DATABASE=wordpress
MARIA_USER=wp_user

# WordPress admin account (username must NOT contain "admin")
WP_ADMIN_USER=placeholder
WP_ADMIN_EMAIL=placeholder@example.com

