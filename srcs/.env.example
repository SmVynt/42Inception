# Paths on host (usually set by Makefile; optional override here for plain `docker compose` from srcs/)
# WP_VOLUME=/home/login/data/wordpress
# DB_VOLUME=/home/login/data/mariadb
# DOMAIN_NAME=login.42.fr

MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=wordpress
MYSQL_USER=wp_user
MYSQL_PASSWORD=change_me_db_user

# WordPress admin account (username must NOT contain "admin")
WP_ADMIN_USER=placeholder
WP_ADMIN_EMAIL=placeholder@example.com
