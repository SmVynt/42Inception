# Non-secret values only.
# Passwords: ../secrets/db_root_password.txt, db_password.txt, wp_password.txt (see secrets/*.example)

# Compose interpolation — required for plain `docker compose` (Makefile also exports these).
# Uncomment and edit, OR run: make ensure-compose-vars  (appends paths from `id -un` if keys are missing)
#WP_VOLUME=/home/yourlogin/data/wordpress
#DB_VOLUME=/home/yourlogin/data/mariadb
#DOMAIN_NAME=yourlogin.42.fr

MARIA_DATABASE=wordpress
MARIA_USER=wp_user
MARIA_PORT=3306

# WordPress admin (username must NOT contain "admin" / "Admin" / "administrator" per subject)
WP_ADMIN_USER=siteowner
WP_ADMIN_EMAIL=siteowner@example.com
WORDPRESS_TITLE=Inception

# Second WordPress user (subject: two users, one admin + one regular)
WP_USER=author42
WP_USER_EMAIL=author42@example.com

WORDPRESS_VERSION=6.4.3

#PORTS
NGINX_PORT=443
WORDPRESS_PORT=9000
MARIA_PORT=3306

#########
#BONUS###
#########

REDIS_HOST=redis
REDIS_PORT=6379
# FTP bonus — passive mode must advertise an address clients can reach (VM IP or DNS).
# If unset, DOMAIN_NAME is used; set explicitly if DNS does not resolve for your client.
# FTP_USER=wpftp
# FTP_PASV_ADDRESS=10.11.12.13
# FTP_PORT=21
